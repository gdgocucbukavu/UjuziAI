rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper: Check if user is admin
    // Primary: check email directly (most reliable)
    // Fallback: check role field in user document
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email in ['abrahamfaith325@gmail.com', 'gdgoncampusucb@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function getBuildathon(buildathonId) {
      return get(/databases/$(database)/documents/buildathons/$(buildathonId));
    }

    function isAcceptedJudge(buildathonId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/buildathons/$(buildathonId)/judges/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/buildathons/$(buildathonId)/judges/$(request.auth.uid)).data.active == true;
    }

    function projectIsRejected(projectData) {
      return projectData.projectStatus in ['rejete', 'rejected'] ||
        projectData.moderationStatus == 'rejected';
    }

    function projectIsDraft(projectData) {
      return projectData.projectStatus in ['brouillon', 'draft'];
    }

    function projectIsPublished(projectData) {
      return projectData.projectStatus in ['publie', 'published'] ||
        projectData.isPublished == true ||
        projectData.isPublic == true;
    }

    function projectIsSubmittedOrApproved(projectData) {
      return projectData.projectStatus in [
          'soumis', 'submitted', 'pending',
          'valide', 'validated', 'approved',
          'publie', 'published'
        ] ||
        projectData.moderationStatus == 'approved' ||
        projectIsPublished(projectData);
    }

    function getProjectVisibility(buildathonData) {
      return buildathonData.projectVisibility in ['all-submitted', 'allsubmitted', 'all']
        ? 'all-submitted'
        : 'published-only';
    }

    function canReadProject(projectData) {
      let buildathonDoc = getBuildathon(projectData.buildathonId);
      let buildathonData = buildathonDoc.data;

      return isAdmin() ||
        (projectData.buildathonId is string && isAcceptedJudge(projectData.buildathonId)) ||
        projectData.submittedBy == request.auth.uid ||
        (
          isAuthenticated() &&
          projectData.buildathonId is string &&
          buildathonData != null &&
          !projectIsDraft(projectData) &&
          !projectIsRejected(projectData) &&
          (
            (getProjectVisibility(buildathonData) == 'all-submitted' && projectIsSubmittedOrApproved(projectData)) ||
            (getProjectVisibility(buildathonData) == 'published-only' && projectIsPublished(projectData))
          )
        );
    }

    function voteKeysOnlyChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'voteCount', 'updatedAt']);
    }

    function likeKeysOnlyChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeUserIds', 'likesCount', 'updatedAt']);
    }

    function feedbackCounterKeysOnlyChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedbackCount', 'commentsCount']);
    }

    function judgeAggregateKeysOnlyChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'judgeScoreTotal',
        'judgeScoreAverage',
        'judgeScoreCount',
        'updatedAt'
      ]);
    }

    function isSafeVoteToggle() {
      let oldVotes = resource.data.votes;
      let newVotes = request.resource.data.votes;

      return oldVotes is list &&
        newVotes is list &&
        request.resource.data.voteCount == newVotes.size() &&
        (
          (
            !oldVotes.hasAny([request.auth.uid]) &&
            newVotes.hasAny([request.auth.uid]) &&
            newVotes.hasAll(oldVotes) &&
            newVotes.size() == oldVotes.size() + 1
          ) ||
          (
            oldVotes.hasAny([request.auth.uid]) &&
            !newVotes.hasAny([request.auth.uid]) &&
            oldVotes.hasAll(newVotes) &&
            oldVotes.size() == newVotes.size() + 1
          )
        );
    }

    function isVoteLockConsistent() {
      let projectBuildathonId = resource.data.buildathonId;
      let lockPath = /databases/$(database)/documents/buildathons/$(projectBuildathonId)/votes/$(request.auth.uid);
      let oldVotes = resource.data.votes;
      let newVotes = request.resource.data.votes;
      let isAddingVote = !oldVotes.hasAny([request.auth.uid]) && newVotes.hasAny([request.auth.uid]);
      let isRemovingVote = oldVotes.hasAny([request.auth.uid]) && !newVotes.hasAny([request.auth.uid]);
      let lockBefore = get(lockPath).data;
      let lockAfter = getAfter(lockPath).data;

      return projectBuildathonId is string &&
        (
          (
            isAddingVote &&
            (
              (lockBefore != null && lockBefore.projectId == resource.id) ||
              (
                lockAfter != null &&
                lockAfter.projectId == resource.id &&
                lockAfter.userId == request.auth.uid &&
                lockAfter.buildathonId == projectBuildathonId
              )
            )
          ) ||
          (
            isRemovingVote &&
            (
              lockBefore == null ||
              lockBefore.projectId == resource.id ||
              lockAfter == null ||
              lockAfter.projectId == resource.id
            )
          )
        );
    }

    function isSafeLikeToggle() {
      let oldLikes = resource.data.likeUserIds;
      let newLikes = request.resource.data.likeUserIds;

      return oldLikes is list &&
        newLikes is list &&
        request.resource.data.likesCount == newLikes.size() &&
        (
          (
            !oldLikes.hasAny([request.auth.uid]) &&
            newLikes.hasAny([request.auth.uid]) &&
            newLikes.hasAll(oldLikes) &&
            newLikes.size() == oldLikes.size() + 1
          ) ||
          (
            oldLikes.hasAny([request.auth.uid]) &&
            !newLikes.hasAny([request.auth.uid]) &&
            oldLikes.hasAll(newLikes) &&
            oldLikes.size() == newLikes.size() + 1
          )
        );
    }

    function isSafeFeedbackCounterSync() {
      return request.resource.data.feedbackCount is int &&
        request.resource.data.commentsCount is int &&
        request.resource.data.feedbackCount >= 0 &&
        request.resource.data.commentsCount >= 0 &&
        request.resource.data.feedbackCount == request.resource.data.commentsCount;
    }

    function isSafeJudgeAggregateSync() {
      return (request.resource.data.judgeScoreTotal is int || request.resource.data.judgeScoreTotal is float) &&
        (request.resource.data.judgeScoreAverage is int || request.resource.data.judgeScoreAverage is float) &&
        request.resource.data.judgeScoreCount is int &&
        request.resource.data.judgeScoreTotal >= 0 &&
        request.resource.data.judgeScoreAverage >= 0 &&
        request.resource.data.judgeScoreCount >= 0;
    }

    function isValidGithubRepoUrl(url) {
      return url is string &&
        url.matches('^https://(www\\.)?github\\.com/[^/]+/[^/]+/?([^\\s]*)$');
    }

    function isValidDemoUrl(url) {
      return url is string &&
        url.matches('^https://[^\\s]+$');
    }

    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      // Any authenticated user can read any user doc (leaderboard, profile)
      allow read: if isAuthenticated();
      
      // Users can create their own profile on signup
      allow create: if isOwner(userId);
      
      // Users can update their own profile; admins can update any.
      // Non-admin users cannot self-elevate role or self-manage bonus points.
      allow update: if isAdmin() || (
        isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'bonusPoints'])
      );
      
      // Only admins can delete users
      allow delete: if isAdmin();
      
      // USER PROGRESS SUBCOLLECTION
      match /progress/{moduleId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }
      
      // USER SUBMISSIONS SUBCOLLECTION
      match /submissions/{submissionId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }

      // BONUS LOGS SUBCOLLECTION
      match /bonusLogs/{logId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAdmin();
        allow update, delete: if isAdmin();
      }
    }
    
    // ============================================
    // EXAMS COLLECTION
    // ============================================
    match /exams/{examId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'in-progress';
      
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      
      allow delete: if isAdmin();
    }
    
    // ============================================
    // MODULE SETTINGS (Admin managed)
    // ============================================
    match /moduleSettings/{moduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============================================
    // TRACKS COLLECTION (Admin managed)
    // ============================================
    match /tracks/{trackId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============================================
    // BADGES COLLECTION (Public verification)
    // ============================================
    match /badges/{badgeId} {
      // Anyone can read (public verification)
      allow read: if true;
      // Authenticated users can create their own badges (from exam completion)
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only admins can update/delete
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // APP SETTINGS (Admin managed exam config etc.)
    // ============================================
    match /appSettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // TEAM PROJECTS (Collaborative projects)
    // ============================================
    match /teamProjects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (
        isAuthenticated() &&
        (
          resource.data.ownerId == request.auth.uid ||
          (resource.data.members is list && resource.data.members.hasAny([request.auth.uid]))
        )
      );
      allow delete: if isAuthenticated() && 
        (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ============================================
    // BUILDATHONS
    // ============================================
    match /buildathons/{buildathonId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      // Admin can fully manage buildathons.
      // Non-admin users can only self-register in participants.
      allow update: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants']) &&
        request.resource.data.participants is list &&
        resource.data.participants is list &&
        request.resource.data.participants.removeAll(resource.data.participants).size() == 1 &&
        request.resource.data.participants.removeAll(resource.data.participants)[0] == request.auth.uid &&
        resource.data.participants.removeAll(request.resource.data.participants).size() == 0
      );
      allow delete: if isAdmin();

      // Per-event vote lock: one doc per user (doc id = uid), writable only by that user/admin.
      match /votes/{userId} {
        allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
        allow create, update: if isAdmin() || (
          isAuthenticated() &&
          request.auth.uid == userId &&
          request.resource.data.diff({}).affectedKeys().hasOnly(['projectId', 'buildathonId', 'userId', 'updatedAt']) &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.buildathonId == buildathonId &&
          request.resource.data.projectId is string
        );
        allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      }

      // Judge invitation lifecycle per buildathon.
      match /judgeInvitations/{inviteeUid} {
        allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == inviteeUid);

        allow create: if isAdmin() &&
          request.resource.data.inviteeUid == inviteeUid &&
          request.resource.data.buildathonId == buildathonId &&
          request.resource.data.status == 'pending';

        allow update: if isAdmin() || (
          isAuthenticated() &&
          request.auth.uid == inviteeUid &&
          resource.data.inviteeUid == request.auth.uid &&
          resource.data.buildathonId == buildathonId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'respondedAt']) &&
          request.resource.data.status in ['accepted', 'declined']
        );

        allow delete: if isAdmin();
      }

      // Active judges assigned to buildathon.
      match /judges/{judgeUid} {
        allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == judgeUid);

        allow create, update: if isAdmin() || (
          isAuthenticated() &&
          request.auth.uid == judgeUid &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.buildathonId == buildathonId &&
          request.resource.data.active == true
        );

        allow delete: if isAdmin();
      }
    }

    // ============================================
    // BUILDATHON PROJECTS
    // ============================================
    match /buildathonProjects/{projectId} {
      allow read: if isAuthenticated() && canReadProject(resource.data);

      // Admin can create any project. Users can only create their own submissions.
      allow create: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.submittedBy == request.auth.uid &&
        request.resource.data.buildathonId is string &&
        isValidGithubRepoUrl(request.resource.data.repoUrl) &&
        isValidDemoUrl(request.resource.data.demoUrl) &&
        request.resource.data.votes is list &&
        request.resource.data.likeUserIds is list &&
        request.resource.data.projectStatus in ['brouillon', 'soumis', 'draft', 'submitted', 'pending'] &&
        request.resource.data.isPublished != true &&
        request.resource.data.isPublic != true
      );

      allow update: if isAdmin() || (
        isAuthenticated() &&
        (
          // Vote toggle restricted to current user + counter consistency.
          (voteKeysOnlyChanged() && isSafeVoteToggle() && isVoteLockConsistent()) ||
          // Like toggle restricted to current user + counter consistency.
          (likeKeysOnlyChanged() && isSafeLikeToggle()) ||
          // Counter sync only (legacy compatibility) with paired value.
          (feedbackCounterKeysOnlyChanged() && isSafeFeedbackCounterSync()) ||
          // Judge aggregate sync from judge scoring flow.
          (
            judgeAggregateKeysOnlyChanged() &&
            isSafeJudgeAggregateSync() &&
            resource.data.buildathonId is string &&
            isAcceptedJudge(resource.data.buildathonId)
          )
        )
      ) || (
        // Owner can update editable project fields only.
        isAuthenticated() &&
        resource.data.submittedBy == request.auth.uid &&
        isValidGithubRepoUrl(request.resource.data.repoUrl) &&
        isValidDemoUrl(request.resource.data.demoUrl) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title',
          'description',
          'category',
          'teamName',
          'repoUrl',
          'demoUrl',
          'tags',
          'stack',
          'techStack',
          'updatedAt'
        ])
      );

      allow delete: if isAdmin() || (isAuthenticated() && resource.data.submittedBy == request.auth.uid);

      match /feedback/{feedbackId} {
        allow read: if isAuthenticated() &&
          canReadProject(get(/databases/$(database)/documents/buildathonProjects/$(projectId)).data) &&
          (resource.data.hidden != true || isAdmin());

        allow create: if isAuthenticated() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.message is string &&
          request.resource.data.message.size() > 0 &&
          request.resource.data.message.size() <= 2000 &&
          request.resource.data.diff({}).affectedKeys().hasOnly([
            'userId', 'authorName', 'authorEmail', 'message', 'createdAt'
          ]);

        allow update: if isAdmin() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'hidden', 'hiddenAt', 'hiddenBy', 'moderationReason'
          ]);

        allow delete: if isAdmin();
      }

      match /feedbackReports/{reportId} {
        allow read: if isAdmin() || (
          isAuthenticated() && resource.data.reportedBy == request.auth.uid
        );

        allow create: if isAuthenticated() &&
          request.resource.data.reportedBy == request.auth.uid &&
          request.resource.data.projectId == projectId &&
          request.resource.data.feedbackId is string &&
          request.resource.data.reason in ['spam', 'inappropriate', 'harassment', 'other'] &&
          request.resource.data.status == 'open';

        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // Judge scoring per project (one doc per judge id).
      match /judgeScores/{judgeId} {
        allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == judgeId);

        allow create, update: if isAuthenticated() &&
          request.auth.uid == judgeId &&
          get(/databases/$(database)/documents/buildathonProjects/$(projectId)).data.buildathonId is string &&
          isAcceptedJudge(get(/databases/$(database)/documents/buildathonProjects/$(projectId)).data.buildathonId) &&
          request.resource.data.judgeId == request.auth.uid &&
          request.resource.data.projectId == projectId &&
          request.resource.data.buildathonId == get(/databases/$(database)/documents/buildathonProjects/$(projectId)).data.buildathonId;

        allow delete: if isAdmin();
      }
    }

    // ============================================
    // PROJECT INVITATIONS
    // ============================================
    match /projectInvitations/{invitationId} {
      allow read: if isAdmin() || (
        isAuthenticated() &&
        (resource.data.invitedUid == request.auth.uid || resource.data.invitedBy == request.auth.uid)
      );

      allow create: if isAuthenticated() &&
        request.resource.data.invitedBy == request.auth.uid &&
        request.resource.data.status == 'pending';

      allow update: if isAdmin();

      allow delete: if isAdmin() || (
        isAuthenticated() &&
        (resource.data.invitedUid == request.auth.uid || resource.data.invitedBy == request.auth.uid)
      );
    }
  }
}
